# ═══════════════════════════════════════════════════════════
#  Next.js + Headless WordPress — Environment Variables
# ═══════════════════════════════════════════════════════════
#
# Copy this file to .env.local for local development:
#   cp .env.example .env.local
#
# NOTE: All variables prefixed with NEXT_PUBLIC_ are
# exposed to the browser. DO NOT put secrets in them.
# ═══════════════════════════════════════════════════════════

# ─── Required (production) ─────────────────────────────────
# These are validated at build time. Build will fail if missing.

WORDPRESS_URL="https://your-wordpress-domain.com"
# Full URL of your WordPress installation (with or without trailing slash)
# Used as the base for all REST API calls.

WORDPRESS_HOSTNAME="your-wordpress-domain.com"
# The hostname only (without protocol). Used by Next.js Image
# component to configure allowed image remote patterns.

WORDPRESS_WEBHOOK_SECRET="your-secret-key-here"
# Shared secret between WordPress plugin and Next.js revalidation
# endpoint. Must match exactly what's configured in:
#   WordPress Admin → Settings → Next.js Revalidation
#
# Generate a strong secret:
#   Windows (PowerShell):  [System.Convert]::ToBase64String((1..32|%{Get-Random -Max 256}))
#   Linux/macOS:           openssl rand -base64 32
#   Online:                https://generate-secret.now.sh/32

# ─── Optional ──────────────────────────────────────────────

ISR_CACHE_TTL=3600
# ISR (Incremental Static Regeneration) cache duration in seconds.
# Default: 3600 (1 hour)
#   - Higher values (7200-86400): Better performance, slower content updates
#   - Lower values (300-1800):   Faster content visibility, more server load
# Content is still instantly updated via webhook revalidation regardless.
# This TTL only affects the cache-freshness check on cold starts.

# ─── Analytics ─────────────────────────────────────────────
# Leave commented out to disable analytics entirely.

# NEXT_PUBLIC_ANALYTICS_PROVIDER="plausible"
# Supported providers: "plausible" | "umami" | "google" | "custom"
#
# NEXT_PUBLIC_ANALYTICS_SRC="https://plausible.io/js/script.js"
# Script URL for your analytics provider.
#
# NEXT_PUBLIC_ANALYTICS_DOMAIN="yourdomain.com"
# Required for Plausible (data-domain attribute).
#
# NEXT_PUBLIC_ANALYTICS_SITE_ID=""
# Required for Umami (data-site-id attribute).
#
# NEXT_PUBLIC_ANALYTICS_MEASUREMENT_ID="G-XXXXXXXX"
# Required for Google Analytics 4 (gtag id).

# ═══════════════════════════════════════════════════════════
#  EXAMPLE: Local Development Setup (Laragon)
# ═══════════════════════════════════════════════════════════
#
# WORDPRESS_URL="http://localhost:8000"
# WORDPRESS_HOSTNAME="localhost"
# WORDPRESS_WEBHOOK_SECRET="dev-secret-do-not-use-in-prod"
# ISR_CACHE_TTL=30
#
# ═══════════════════════════════════════════════════════════